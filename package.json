{
  "name": "storyboard-creator",
  "private": true,
  "version": "1.5.0",
  "homepage": "https://sbc.haak3.de",
  "description": "Eine rein clientseitige Web-App für Lernende zum Erstellen von Storyboards (Film, Fotostory, Rede).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChristianHaake/Storyboard-Creator.git"
  },
  "author": "Christian Haake",
  "keywords": [
    "storyboard",
    "education",
    "react",
    "vite",
    "dnd-kit",
    "pdf-export",
    "offline-first"
  ],
  "license": "GPL-3.0-only",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/clean-build-output.mjs",
    "build": "tsc -b && vite build && node scripts/clean-cloudflare-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"*.{js,ts,json,md}\""
  },
  "overrides": {
    "brace-expansion": "2.1.2"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@haak3/ui": "workspace:*",
    "fflate": "^0.8.3",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
